# Novel Writing Runtime Configuration
# Copy this file to .env and fill in your values

# === LLM Provider ===
LLM_API_KEY=sk-your-api-key-here
NWR_LLM_BASE_URL=https://opencode.ai/zen/go/v1
NWR_LLM_MODEL=deepseek-v4-flash
NWR_LLM_PROVIDER=openai_compatible
NWR_LLM_MAX_RETRIES=1
NWR_LLM_TEMPERATURE=0.7
NWR_LLM_MAX_TOKENS=4096

# === Storage ===
NWR_STORAGE_BASE_PATH=./novel_projects
NWR_DB_PATH=

# === Context ===
NWR_CONTEXT_TOKEN_BUDGET=8000

# === Logging ===
NWR_LOG_LEVEL=INFO
NWR_LOG_FORMAT=text
NWR_LOG_FILE=

# === Auth (empty = disabled) ===
NWR_AUTH_TOKEN=

# === LLM Cache ===
NWR_LLM_CACHE_ENABLED=false
NWR_LLM_CACHE_TTL=86400
NWR_LLM_CACHE_PATH=
