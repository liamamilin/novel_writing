# Novel Writing Runtime Configuration
# Copy this file to .env and fill in your values

# LLM Provider
NWR_LLM_BASE_URL=https://opencode.ai/zen/go/v1
NWR_LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=sk-your-api-key-here

# Storage
NWR_STORAGE_BASE_PATH=/app/novel_projects

# Logging
NWR_LOG_LEVEL=INFO
NWR_LOG_FORMAT=text

# Auth (empty = disabled)
NWR_AUTH_TOKEN=

# LLM Cache (disabled by default)
NWR_LLM_CACHE_ENABLED=false
